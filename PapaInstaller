if(-d flag used){
    sudo apt-get dist-upgrade
    sudo add-apt-repository ppa:paparazzi-uav/ppa
    sudo apt-get update
    sudo apt-get install paparazzi-dev paparazzi-arm-multilib git
    git clone git@github.com:paparazzi/paparazzi.git ~/paparazzi
    cd ~/paparazzi/
    git checkout master
    make
    }

if(-c flage used){
    sudo apt-get dist-upgrade
    sudo add-apt-repository ppa:paparazzi-uav/ppa
    sudo apt-get update
    sudo apt-get install paparazzi-dev paparazzi-arm-multilib git
    git clone git@github.com:cnuuaslab/paparazzi.git~/paparazzi
    cd ~/paparazzi/
    git remote add upstream git@github.com:cnuuaslab/paparazzi.git
    git checkout master
    make
    }
    

if(Paparazzi is already installed ){
    cd ~/paparazzi/
    git pull
    make
    }
